    "### Correlation Analysis and Linear Regression (Dataset #1)\n",
    "\n",
    "We compute Pearson correlations between daily usage hours and all continuous outcome variables, then fit a simple OLS regression to quantify the relationship between usage and mental health score."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8c6635a1",
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.patches as mpatches\n",
    "\n",
    "# Correlation table\n",
    "print(\"=== DS1 Pearson Correlations with Avg_Daily_Usage_Hours (n=549) ===\\n\")\n",
    "corr_vars = {\n",
    "    'Addiction Score':             'Addicted_Score',\n",
    "    'Mental Health Score':         'Mental_Health_Score',\n",
    "    'Sleep Hours per Night':       'Sleep_Hours_Per_Night',\n",
    "    'Conflicts Over Social Media': 'Conflicts_Over_Social_Media',\n",
    "    'Academic Impact (binary)':    'acad_impact_bin',\n",
    "}\n",
    "print(f\"  {'Variable':<35} {'r':>8} {'p':>12} {'sig':>5}\")\n",
    "print(\"  \" + \"-\"*63)\n",
    "for label, col in corr_vars.items():\n",
    "    r, p = pearsonr(df1['Avg_Daily_Usage_Hours'], df1[col])\n",
    "    sig = '***' if p<0.001 else '**' if p<0.01 else '*' if p<0.05 else 'ns'\n",
    "    print(f\"  {label:<35} {r:>8.3f} {p:>12.4f} {sig:>5}\")\n",
    "\n",
    "# OLS Regression: Mental Health ~ Daily Usage\n",
    "x = df1['Avg_Daily_Usage_Hours'].values\n",
    "y = df1['Mental_Health_Score'].values\n",
    "n = len(x); xm, ym = x.mean(), y.mean()\n",
    "b1 = ((x - xm) * (y - ym)).sum() / ((x - xm)**2).sum()\n",
    "b0 = ym - b1 * xm\n",
    "yhat = b0 + b1 * x\n",
    "ss_res = ((y - yhat)**2).sum(); ss_tot = ((y - ym)**2).sum()\n",
    "r2 = 1 - ss_res / ss_tot\n",
    "se_b1 = np.sqrt(ss_res / (n - 2) / ((x - xm)**2).sum())\n",
    "t_b1  = b1 / se_b1\n",
    "\n",
    "print(f\"\\n=== OLS Regression: Mental Health Score ~ Daily Usage Hours ===\")\n",
    "print(f\"  Intercept (b0): {b0:.3f}\")\n",
    "print(f\"  Slope     (b1): {b1:.3f}  (SE={se_b1:.4f}, t={t_b1:.2f})\")\n",
    "print(f\"  R-squared:      {r2:.3f}\")\n",
    "print(f\"  Each additional hour/day of usage is associated with a {abs(b1):.2f}-point\")\n",
    "print(f\"  decrease in mental health score (1-10 scale).\")\n",
    "\n",
    "# Figure 3: Scatter + regression + correlation bars\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n",
    "\n",
    "colors_scatter = [PLATFORM_COLORS[p] for p in df1['Most_Used_Platform']]\n",
    "axes[0].scatter(df1['Avg_Daily_Usage_Hours'], df1['Mental_Health_Score'],\n",
    "                c=colors_scatter, alpha=0.4, s=20)\n",
    "xfit = np.linspace(df1['Avg_Daily_Usage_Hours'].min(), df1['Avg_Daily_Usage_Hours'].max(), 100)\n",
    "axes[0].plot(xfit, b0 + b1 * xfit, 'k-', linewidth=2)\n",
    "legend_handles = [mpatches.Patch(color=PLATFORM_COLORS[p], label=p) for p in PLATFORMS]\n",
    "legend_handles.append(plt.Line2D([0],[0], color='black', linewidth=2,\n",
    "                                  label=f'OLS fit (R²={r2:.2f})'))\n",
    "axes[0].legend(handles=legend_handles, fontsize=8, loc='upper right')\n",
    "axes[0].set_xlabel('Avg Daily Usage (hours)')\n",
    "axes[0].set_ylabel('Mental Health Score (1–10)')\n",
    "axes[0].set_title('Mental Health vs Daily Usage (DS1)')\n",
    "\n",
    "corr_labels = list(corr_vars.keys())\n",
    "corr_vals   = [pearsonr(df1['Avg_Daily_Usage_Hours'], df1[col])[0] for col in corr_vars.values()]\n",
    "bar_colors  = ['#d62728' if v < 0 else '#1f77b4' for v in corr_vals]\n",
    "axes[1].barh(corr_labels, corr_vals, color=bar_colors, edgecolor='black', linewidth=0.5)\n",
    "axes[1].axvline(0, color='black', linewidth=0.8)\n",
    "axes[1].set_xlabel(\"Pearson r with Daily Usage Hours\")\n",
    "axes[1].set_title(\"Correlations with Daily Usage (DS1)\")\n",
    "for i, v in enumerate(corr_vals):\n",
    "    axes[1].text(v + (0.01 if v >= 0 else -0.01), i, f'{v:.3f}',\n",
    "                 va='center', ha='left' if v >= 0 else 'right', fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('results/fig3_correlation_regression.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Saved: results/fig3_correlation_regression.png\")"
   ]
