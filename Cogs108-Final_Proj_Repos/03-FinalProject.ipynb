    "}\n",
    "\n",
    "# ── Pearson r with two-tailed p-value (no scipy needed) ──────────────────────\n",
    "def pearsonr(x, y):\n",
    "    x, y = np.array(x, dtype=float), np.array(y, dtype=float)\n",
    "    mask = ~(np.isnan(x) | np.isnan(y))\n",
    "    x, y = x[mask], y[mask]\n",
    "    n = len(x)\n",
    "    if n < 3: return 0, 1\n",
    "    mx, my = x.mean(), y.mean()\n",
    "    num = ((x - mx) * (y - my)).sum()\n",
    "    den = np.sqrt(((x - mx)**2).sum() * ((y - my)**2).sum())\n",
    "    if den == 0: return 0, 1\n",
    "    r = np.clip(num / den, -1, 1)\n",
    "    t = r * np.sqrt(n - 2) / np.sqrt(max(1 - r**2, 1e-15))\n",
    "    # Incomplete beta for p-value\n",
    "    def _betai(a, b, x):\n",
    "        if x <= 0: return 0.0\n",
    "        if x >= 1: return 1.0\n",
    "        lb = lgamma(a) + lgamma(b) - lgamma(a + b)\n",
    "        def cf(a, b, x):\n",
    "            qab=a+b; qap=a+1; qam=a-1; c=1.; d=1-qab*x/qap\n",
    "            if abs(d)<1e-30: d=1e-30\n",
    "            d=1/d; h=d\n",
    "            for m in range(1,201):\n",
    "                m2=2*m; aa=m*(b-m)*x/((qam+m2)*(a+m2))\n",
    "                d=1+aa*d; c=1+aa/c\n",
    "                if abs(d)<1e-30: d=1e-30\n",
    "                if abs(c)<1e-30: c=1e-30\n",
    "                d=1/d; h*=d*c; aa=-(a+m)*(qab+m)*x/((a+m2)*(qap+m2))\n",
    "                d=1+aa*d; c=1+aa/c\n",
    "                if abs(d)<1e-30: d=1e-30\n",
    "                if abs(c)<1e-30: c=1e-30\n",
    "                d=1/d; delta=d*c; h*=delta\n",
    "                if abs(delta-1)<3e-7: break\n",
    "            return exp(log(x)*a+log(1-x)*b-lb)*h/a\n",
    "        df_=float(n-2); x2=df_/(df_+t*t)\n",
    "        mid=(df_/2+1)/(df_/2+0.5+2)\n",
    "        return cf(df_/2,0.5,x2) if x2<mid else 1-cf(0.5,df_/2,1-x2)\n",
    "    p = _betai(float(n-2)/2, 0.5, float(n-2)/(float(n-2)+t*t))\n",
    "    return float(r), float(p)\n",
    "\n",
    "# ── Welch's t-test (handles unequal variances, no scipy needed) ──────────────\n",
    "def welch_ttest(a, b):\n",
    "    a = np.array(a, dtype=float); a = a[~np.isnan(a)]\n",
    "    b = np.array(b, dtype=float); b = b[~np.isnan(b)]\n",
    "    na, nb = len(a), len(b)\n",
    "    ma, mb = a.mean(), b.mean()\n",
    "    va, vb = a.var(ddof=1), b.var(ddof=1)\n",
    "    se = np.sqrt(va/na + vb/nb)\n",
    "    t  = (ma - mb) / se\n",
    "    df = (va/na + vb/nb)**2 / ((va/na)**2/(na-1) + (vb/nb)**2/(nb-1))\n",
    "    def _betai(a, b, x):\n",
    "        if x <= 0: return 0.0\n",
    "        if x >= 1: return 1.0\n",
    "        lb = lgamma(a) + lgamma(b) - lgamma(a+b)\n",
    "        def cf(a, b, x):\n",
    "            qab=a+b; qap=a+1; qam=a-1; c=1.; d=1-qab*x/qap\n",
    "            if abs(d)<1e-30: d=1e-30\n",
    "            d=1/d; h=d\n",
    "            for m in range(1,201):\n",
    "                m2=2*m; aa=m*(b-m)*x/((qam+m2)*(a+m2))\n",
    "                d=1+aa*d; c=1+aa/c\n",
    "                if abs(d)<1e-30: d=1e-30\n",
    "                if abs(c)<1e-30: c=1e-30\n",
    "                d=1/d; h*=d*c; aa=-(a+m)*(qab+m)*x/((a+m2)*(qap+m2))\n",
    "                d=1+aa*d; c=1+aa/c\n",
    "                if abs(d)<1e-30: d=1e-30\n",
    "                if abs(c)<1e-30: c=1e-30\n",
    "                d=1/d; delta=d*c; h*=delta\n",
    "                if abs(delta-1)<3e-7: break\n",
    "            return exp(log(x)*a+log(1-x)*b-lb)*h/a\n",
    "        x2=df/(df+t*t); mid=(df/2+1)/(df/2+0.5+2)\n",
    "        return cf(df/2,0.5,x2) if x2<mid else 1-cf(0.5,df/2,1-x2)\n",
    "    p = _betai(df/2, 0.5, df/(df+t*t))\n",
    "    return ma, mb, float(t), float(p)\n",
    "\n",
    "print(\"✓ Setup complete — imports, constants, and stat functions loaded\")"
   ]
