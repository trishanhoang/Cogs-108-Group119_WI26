   "source": [
    "# ── F. Cleaning ───────────────────────────────────────────────────────────────\n",
    "\n",
    "# Drop uninformative / out-of-scope columns\n",
    "# Column 19: all nulls  |  Timestamp, socioeconomic status, study time,\n",
    "# attendance, physical activity, withdrawal symptoms: out of scope\n",
    "df2_clean = df2_raw.drop(columns=[\n",
    "    'Column 19', 'Timestamp',\n",
    "    \"Socioeconomic status (Parent's education level)\",\n",
    "    'Study time (In Hours)', 'Attendance rate (In Percentile)',\n",
    "    'Most time spent in a day', 'Physical activity (30 min+)',\n",
    "    'Withdrawal symptoms (Side effects of not using social media)'\n",
    "])\n",
    "\n",
    "# --- Age: extract first 2-digit number ----------------------------------------\n",
    "# Raw entries include \"19 years\", \"19+\", and birth years like \"2001\"\n",
    "# Grabbing the first 2-digit sequence handles all cases cleanly\n",
    "df2_clean['Age_clean'] = (\n",
    "    df2_clean['Age'].astype(str)\n",
    "    .str.extract(r'(\\d{2})')\n",
    "    .astype(float)\n",
    ")\n",
    "\n",
    "# --- Time spent: extract leading integer, cap implausible values > 16 h/day ---\n",
    "# Entries like \"30 minutes\" are parsed as 30 by the integer regex — implausible\n",
    "# as a daily hour count, so we cap anything > 16 to NaN\n",
    "df2_clean['Time_spent_cleaned'] = (\n",
    "    df2_clean['Time spent in social media (hours)']\n",
    "    .astype(str).str.extract(r'(\\d+)').astype(float)\n",
    ")\n",
    "df2_clean.loc[df2_clean['Time_spent_cleaned'] > 16, 'Time_spent_cleaned'] = np.nan\n",
    "\n",
    "# --- GPA: decimal-aware regex to avoid grabbing year numbers ------------------\n",
    "# Bug in naive regex: r'(\\d+\\.?\\d*)' extracts 2021 from \"Hsc 2021 4.58 science\"\n",
    "# Fix: look-behind (?<!\\d) ensures we only match a decimal not preceded by a digit\n",
    "df2_clean['GPA_clean'] = (\n",
    "    df2_clean['Last Academic Result (GPA/CGPA)']\n",
    "    .astype(str).str.extract(r'(?<!\\d)(\\d\\.\\d+)').astype(float)\n",
    ")\n",
    "# Normalize 5-point scale entries down to 4.0 scale\n",
    "df2_clean.loc[df2_clean['GPA_clean'] > 4.0, 'GPA_clean'] = (\n",
    "    df2_clean.loc[df2_clean['GPA_clean'] > 4.0, 'GPA_clean'] / 5 * 4\n",
    ")\n",
    "\n",
    "# Select final columns\n",
    "df2_clean = df2_clean[[\n",
    "    'Age_clean', 'Gender', 'Residence Area', 'Education Level',\n",
    "    'Social Media Platform', 'Time_spent_cleaned',\n",
    "    'Sleep Disturbance on Sleep Quality', 'Mood Modification Scale',\n",
    "    'Anxiety Scale', 'Depression Scale', 'Self-esteem Scale',\n",
    "    'Social Media Distraction During Academic Activities', 'GPA_clean'\n",
    "]]\n",
    "\n",
    "# Drop rows where GPA could not be reliably parsed\n",
    "df2_clean = df2_clean.dropna(subset=['GPA_clean'])\n",
    "\n",
    "print(f\"Cleaned DS2: {df2_clean.shape[0]} rows, {df2_clean.shape[1]} columns\")\n",
    "print(f\"Time_spent valid: {df2_clean['Time_spent_cleaned'].notna().sum()} \"\n",
    "      f\"| NaN (capped/unparseable): {df2_clean['Time_spent_cleaned'].isna().sum()}\")\n",
    "print(f\"Age_clean valid:  {df2_clean['Age_clean'].notna().sum()}\")\n",
    "print(f\"GPA: mean={df2_clean['GPA_clean'].mean():.3f}, median={df2_clean['GPA_clean'].median():.3f}\")\n",
    "\n",
    "os.makedirs('data/02-processed', exist_ok=True)\n",
    "df2_clean.to_csv('data/02-processed/survey_clean.csv', index=False)\n",
    "df2_clean.head()"
   ]
