    "\n",
    "os.makedirs('results', exist_ok=True)\n",
    "\n",
    "# Platform constants\n",
    "PLATFORMS       = ['TikTok', 'Instagram', 'Snapchat', 'Facebook', 'YouTube']\n",
    "SHORT_FORM      = ['TikTok', 'Instagram', 'Snapchat']\n",
