    "\n",
    "# Assign geographic regions for cross-regional analysis\n",
    "def assign_region(country):\n",
    "    south_asia    = ['India', 'Bangladesh', 'Pakistan', 'Sri Lanka', 'Nepal']\n",
    "    east_asia     = ['Japan', 'China', 'South Korea', 'Singapore', 'Taiwan']\n",
    "    western_eu    = ['France', 'Germany', 'Spain', 'Italy', 'Switzerland', 'Denmark',\n",
    "                     'Ireland', 'UK', 'Netherlands', 'Belgium', 'Sweden', 'Norway',\n",
    "                     'Finland', 'Austria']\n",
    "    eastern_eu    = ['Russia', 'Turkey', 'Poland', 'Ukraine', 'Romania']\n",
    "    north_america = ['USA', 'Canada', 'Mexico']\n",
    "    latin_america = ['Brazil', 'Argentina', 'Colombia', 'Chile', 'Peru']\n",
    "    if country in south_asia:    return 'South Asia'\n",
    "    if country in east_asia:     return 'East Asia'\n",
    "    if country in western_eu:    return 'Western Europe'\n",
    "    if country in eastern_eu:    return 'Eastern Europe/Turkey'\n",
    "    if country in north_america: return 'North America'\n",
    "    if country in latin_america: return 'Latin America'\n",
    "    return 'Other'\n",
    "\n",
    "df1_raw['Region'] = df1_raw['Country'].apply(assign_region)\n",
